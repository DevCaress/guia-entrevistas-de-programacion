---
type Reference = {
  label: string;
  url: string;
};

type Props = {
  references?: Reference[];
};

const { references = [] } = Astro.props;
---

{references.length > 0 && (
  <section class="mt-12 border-t border-[var(--border)] pt-6" aria-labelledby="references-title">
    <h2 id="references-title">Referencias</h2>
    <ul class="grid gap-[0.6rem] pl-[1.2rem]">
      {references.map((reference) => (
        <li>
          <a href={reference.url} rel="noreferrer" target="_blank">{reference.label}</a>
        </li>
      ))}
    </ul>
  </section>
)}
